# ============================================================
# AIStock 环境变量配置
# 复制此文件为 .env 并填写真实值
# ============================================================

# ---- 环境 ----
ENV=dev                    # dev | prod
LOG_LEVEL=INFO            # DEBUG | INFO | WARNING | ERROR

# ---- 数据库 ----
DATABASE_URL=sqlite:///./aistock.db
# PostgreSQL 示例（可选）：
# DATABASE_URL=postgresql://user:password@localhost:5432/aistock

# ---- 配置文件 ----
CONFIG_PATH=config/settings.yaml

# ---- Tushare 数据源 ----
# 申请地址：https://tushare.pro/register
TUSHARE_TOKEN=your_tushare_token_here

# ---- 交易模式 ----
# paper = 模拟交易（默认）
# live  = 实盘交易（需配合 broker_type 和券商配置）
TRADING_MODE=paper

# ---- 券商配置（实盘时填写）----
# broker_type: sim | qmt | gf | os
BROKER_TYPE=sim
# QMT 配置
QMT_ACCOUNT=your_qmt_account
QMT_PASSWORD=your_qmt_password
QMT_SESSION_PATH=
QMT_MODE=mini

# ---- 告警 ----
# 企业微信机器人 Webhook 或其他告警 URL
ALERT_WEBHOOK=
